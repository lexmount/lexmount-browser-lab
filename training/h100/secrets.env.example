# Secrets template for the H100 recipe.
#
# Copy next to the launch scripts, fill in every non-optional value, protect:
#   cp training/h100/secrets.env.example training/h100/secrets.env
#   chmod 600 training/h100/secrets.env
# The file is consumed via docker --env-file by the Ray containers and the
# NeMo-Gym sidecar. Never commit the filled-in file (secrets.env is
# gitignored).

# ---------------------------------------------------------------------------
# Lexmount cloud browser (rollout environment backend, BROWSER_BACKEND=lexmount)
# ---------------------------------------------------------------------------
# Session API endpoint. browser.lexmount.com serves the HTML console and
# redirects API routes; api.lexmount.com serves the JSON session API required
# by the pinned lexmount==0.5.12 SDK.
# REQUIRED explicit override: the lexmount SDK defaults to api.lexmount.cn
# when unset — set this to the API base shown in your dashboard.
LEXMOUNT_BASE_URL=https://api.lexmount.com
# API key + project: create a project in the Lexmount console
# (https://browser.lexmount.com) and issue a key with browser-session scope.
# The validated run drove 64 concurrent sessions on a single key; make sure
# the project quota allows MAX_CONCURRENT_SESSIONS (default 64).
LEXMOUNT_API_KEY=<YOUR_LEXMOUNT_API_KEY>
LEXMOUNT_PROJECT_ID=<YOUR_LEXMOUNT_PROJECT_ID>
# Optional: pin a Lexmount region after it passes the CDP reachability
# preflight; rollout sessions then reuse it.
# LEXMOUNT_REGION=<REGION_NAME>

# Optional egress proxy, only if the Lexmount project egress cannot reach a
# required WebVoyager site. All three values are required together.
# LEXMOUNT_EXTERNAL_PROXY_SERVER=http://<HOST>:<PORT>
# LEXMOUNT_EXTERNAL_PROXY_USERNAME=<USERNAME>
# LEXMOUNT_EXTERNAL_PROXY_PASSWORD=<PASSWORD>

# ---------------------------------------------------------------------------
# Completion judge (binary reward model)
# ---------------------------------------------------------------------------
# Any OpenAI-compatible chat-completions endpoint that serves the judge model.
# The validated run used deepseek-v4-flash. Our internal gateway is NOT
# reachable from outside; point these at your own deployment of the model
# (e.g. an api provider, or a self-hosted OpenAI-compatible server).
# The environment reads OPENAI_* first; JUDGE_* act as overrides when you
# need a judge endpoint separate from other OpenAI-compatible usage.
OPENAI_API_KEY=<YOUR_JUDGE_API_KEY>
OPENAI_BASE_URL=<YOUR_JUDGE_OPENAI_COMPATIBLE_BASE_URL>
OPENAI_MODEL=deepseek-v4-flash
# Optional explicit judge overrides (take precedence over OPENAI_*):
# JUDGE_API_KEY=<YOUR_JUDGE_API_KEY>
# JUDGE_BASE_URL=<YOUR_JUDGE_OPENAI_COMPATIBLE_BASE_URL>
# JUDGE_MODEL=deepseek-v4-flash

# ---------------------------------------------------------------------------
# Model + data (paths, not secrets; documented here for completeness)
# ---------------------------------------------------------------------------
# The policy model is stock Qwen/Qwen3-8B from Hugging Face; download it to
# the path passed as MODEL_PATH (default /models/Qwen3-8B):
#   huggingface-cli download Qwen/Qwen3-8B --local-dir /models/Qwen3-8B
# Set HF_TOKEN only if your network requires authenticated HF downloads.
# HF_TOKEN=<YOUR_HF_TOKEN>
# Training data is built in-repo (data/webvoyager-clean); no credential needed.
