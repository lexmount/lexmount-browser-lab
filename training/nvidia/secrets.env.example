# Copy this file to secrets.env, fill in the values, then run:
# chmod 600 secrets.env
# Global console: https://browser.lexmount.com
# SDK session API: browser.lexmount.com redirects API routes to HTML, while
# api.lexmount.com returns the JSON session API required by Lexmount 0.5.12.
LEXMOUNT_BASE_URL=https://api.lexmount.com
LEXMOUNT_API_KEY=
LEXMOUNT_PROJECT_ID=
# Optional: pin a Lexmount region after it passes the CDP reachability
# preflight. The same region is then used by rollout sessions.
# LEXMOUNT_REGION=beijing-1

# Optional: use these only if the project-level Lexmount provider egress cannot
# reach a required WebVoyager site. All three values are required together.
# LEXMOUNT_EXTERNAL_PROXY_SERVER=http://host:port
# LEXMOUNT_EXTERNAL_PROXY_USERNAME=
# LEXMOUNT_EXTERNAL_PROXY_PASSWORD=

# Completion judge. OPENAI_MODEL is documented here even though the current
# environment config pins the same model name explicitly.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=glm-5.2
